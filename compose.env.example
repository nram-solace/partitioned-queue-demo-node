# Copy to .env in the repo root (required for bundled-broker Docker stack):
#   cp compose.env.example .env
#
# COMPOSE_FILE merges docker-compose.broker.yml (in-network SOLACE_HOST for Node apps).
# SOLACE_HOST in demo.env stays ws://localhost:8008 for host scripts; compose overrides containers.

COMPOSE_PROFILES=broker
COMPOSE_FILE=docker-compose.yml:docker-compose.broker.yml
