# Copy to `demo.env` in the repo root (`cp demo.env.example demo.env`).
# Single source of truth for npm run and docker compose — see .dev/pm/impl-central-config.md
# After edits: npm run sync-config (host frontend) or recreate demo-frontend (Docker).

# App version
VERSION=3.5.2

# --- Solace Web Transport (Node apps: publisher, consumer) ---
SOLACE_HOST=wss://nram-gke-poc.messaging.solace.cloud:443
SOLACE_VPN=nram-prod1
SOLACE_USERNAME=pqdemo
SOLACE_PASSWORD="Et2psqF}b6^km.w4"
# --- SEMP / solace-init (broker provisioning) ---
SEMP_HOST=/nram-gke-poc.messaging.solace.cloud
SEMP_SCHEME=https
SEMP_PORT=943
MSG_VPN=nram-prod1
SEMP_USER=nram-prod1-admin
SEMP_PASS="7pm31ob4h22pg3pabcocsh55u2"
SEMP_WAIT_MAX_ITERATIONS=120
SEMP_WAIT_SLEEP_SECS=3
# Solace Queue properties - DONOT CHANGE
QUEUE_MAX_SPOOL_MB=100
QUEUE_MAX_TTL=60

# Browser URL (optional). Defaults to SOLACE_HOST. Set when the UI runs outside Docker network:
#   Docker Compose: SOLACE_PUBLIC_URL=ws://localhost:8008  (while SOLACE_HOST=ws://solace-broker:8008 in compose overrides)
#   Azure / remote VM: SOLACE_PUBLIC_URL=ws://<public-ip>:8008
# SOLACE_PUBLIC_URL=ws://localhost:8008

# --- Demo runtime ---
PUBLISH_RATE=3 # msgs per second. Donot increase unless broker and network can handle
NQ_PREDICTION_CONSUMER=1

# All profiles under profiles/ load automatically (finance, retail, airline-carrier, airline-hub).
# PROFILES_DIR=./profiles

# Low level settings - DONOT CHANGE
CATALOG_SEND_BUFFER_MAX_SIZE=8388608
CATALOG_EVENT_MIN_INTERVAL_MS=80
