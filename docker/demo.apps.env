# Docker stack (broker apps + solace-init). After edits:
#   docker compose up -d --force-recreate solace-init consumer publisher

SOLACE_HOST=ws://solace-broker:8008
SOLACE_VPN=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=default

PUBLISH_RATE=2
NQ_PREDICTION_CONSUMER=1

# solace-init (SEMP)
MSG_VPN=default
SEMP_PORT=8080
SEMP_WAIT_MAX_ITERATIONS=120
SEMP_WAIT_SLEEP_SECS=3
