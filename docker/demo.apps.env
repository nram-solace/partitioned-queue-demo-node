# Single place to tune the Docker stack (broker apps + solace-init).
# After edits: docker compose up -d --force-recreate solace-init consumer publisher
#
# Profile: path relative to /app in the Node image (= repo layout).
# PARTITION_COUNT must equal messaging.partitionKeys.length in that JSON (8 finance, 5 retail).

SOLACE_HOST=ws://solace-broker:8008
SOLACE_VPN=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=default
WS_PORT=8081
WS_BIND_HOST=0.0.0.0

DEMO_PROFILE=./profiles/finance.json
#DEMO_PROFILE=./profiles/retail.json
PARTITION_COUNT=8

PUBLISH_RATE=2
NQ_PREDICTION_CONSUMER=1

QUEUE_PARTITIONED=Demo_PQ
QUEUE_NON_EXCLUSIVE=Demo_NQ
QUEUE_EXCLUSIVE=Demo_EQ

# solace-init (SEMP) — same names as setup-solace.sh
QUEUE_PQ=Demo_PQ
QUEUE_NQ=Demo_NQ
QUEUE_EQ=Demo_EQ
DEMO_TOPIC_SUB=solace/demo/>
MSG_VPN=default
SEMP_PORT=8080
SEMP_WAIT_MAX_ITERATIONS=120
SEMP_WAIT_SLEEP_SECS=3
