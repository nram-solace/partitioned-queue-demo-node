# Copy to `demo.env` in the repo root (`cp demo.env.example demo.env`).
# Single source of truth for npm run and docker compose — see .dev/pm/impl-central-config.md
# After edits: npm run sync-config (host frontend) or recreate demo-frontend (Docker).

# --- Solace Web Transport (Node apps: publisher, consumer) ---
# Host npm / broker on localhost:
SOLACE_HOST=ws://localhost:8008
# Docker bundled broker (docker compose up — SOLACE_HOST set by docker-compose.broker.yml):
#   ws://solace-broker:8008
# External broker (docker compose -f docker-compose.minimal.yml) — Solace Cloud example:
#   SOLACE_HOST=wss://<host>:443
SOLACE_VPN=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=default

# Browser URL (optional). Defaults to SOLACE_HOST.
#   Docker bundled broker: SOLACE_PUBLIC_URL=ws://localhost:8008
#   Azure / remote VM: SOLACE_PUBLIC_URL=ws://<public-ip>:8008
#   Solace Cloud: same wss:// URL as Web Messaging
# SOLACE_PUBLIC_URL=ws://localhost:8008

# --- Demo runtime ---
PUBLISH_RATE=10
NQ_PREDICTION_CONSUMER=1
VERSION=3.4

# Catalog UI session (consumer → solace/catalog/events); optional tuning for cloud / 4 profiles
# CATALOG_SEND_BUFFER_MAX_SIZE=4194304
# CATALOG_EVENT_MIN_INTERVAL_MS=50

# All profiles under profiles/ load automatically (finance, retail, airline-carrier, airline-hub).
# Node apps (cwd /app in Docker): PROFILES_DIR=./profiles is fine.
# solace-init uses /app/profiles via compose; setup-solace.sh resolves ./profiles → repo/profiles.

# --- SEMP / setup-solace.sh (provisioning only — not used by Node apps at runtime) ---
# SEMP_HOST is the management API hostname (NOT the ws:// / wss:// URL above).
#
# Run from laptop against Docker broker on localhost:
#   SEMP_HOST=localhost
#   SEMP_PORT=8080
#   SEMP_SCHEME=http
#   MSG_VPN=default
#   SEMP_USER=admin
#   SEMP_PASS=admin
#
# Solace Cloud (use console SEMP host, usually *.solacecloud.com — not *.messaging.solace.cloud):
#   SEMP_HOST=your-service.solacecloud.com
#   SEMP_SCHEME=https
#   SEMP_PORT=943
#   MSG_VPN=<your-vpn>
#   SEMP_USER=<management-user>
#   SEMP_PASS=<management-password>
#
# If SEMP_HOST is omitted, setup-solace.sh defaults to solace-broker (only works inside Docker network).
#
# Demo queue defaults applied on create/update (setup-solace.sh):
#   QUEUE_MAX_SPOOL_MB=1024   # 1 GiB message spool per queue
#   QUEUE_MAX_TTL=60          # seconds (respectTtlEnabled set by script)
MSG_VPN=default
SEMP_PORT=8080
SEMP_SCHEME=http
SEMP_WAIT_MAX_ITERATIONS=120
SEMP_WAIT_SLEEP_SECS=3
