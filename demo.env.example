# Copy to `demo.env` in the repo root and adjust values (`cp demo.env.example demo.env`).
# Solace PubSub+ Connection Settings
SOLACE_HOST=ws://localhost:8008
SOLACE_VPN=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=default

# Dashboard UI: solace/catalog/ (data) + solace/command/ (control). See .dev/pm/impl-profile-selection.md.
# Browser Web Transport — public VM: use host IP in frontend/public/config.js.
# VITE_SOLACE_URL=ws://localhost:8008
# VITE_DASHBOARD_VERSION=3.1

# All profiles under profiles/ are loaded automatically (queue names in each profile JSON).
# Optional: override profiles directory (default ./profiles)
# PROFILES_DIR=./profiles

PUBLISH_RATE=10
NQ_PREDICTION_CONSUMER=1
