# Copy to `demo.env` in the repo root and adjust values (`cp demo.env.example demo.env`).
# Solace PubSub+ Connection Settings
SOLACE_HOST=ws://localhost:8008
SOLACE_VPN=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=default

# Dashboard UI topics live under solace/catalog/ (see .dev/pm/impl-message-catalog-over-solace.md).
# Browser Web Transport — public VM: use host IP, not localhost (or set in frontend/public/config.js).
# VITE_SOLACE_URL=ws://localhost:8008
# VITE_SOLACE_VPN=default
# VITE_SOLACE_USERNAME=default
# VITE_SOLACE_PASSWORD=default

# Demo profile — JSON relative to repo root or absolute path. Drives topics, payloads, partition keys, and UI copy.
# Broker topic subscription should cover profile topics (e.g. solace/demo/> when using bundled docker compose init).
DEMO_PROFILE=./profiles/finance.json

# Publisher Settings
PUBLISH_RATE=10

# Price prediction (finance profile): NQ dashed line uses one consumer index (1–5). Match backend and frontend.
NQ_PREDICTION_CONSUMER=1
# Set at Vite build/dev time for the dashboard (see frontend/.env.example or vite config).
# VITE_NQ_PREDICTION_CONSUMER=1

# Deprecated when DEMO_PROFILE is set (values come from the profile file). Kept for broker docs compatibility only.
TOPIC_PREFIX=stocks/orders
SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA,NVDA,META,IBM

# Queue names (must match broker / solace-init when using Docker)
QUEUE_PARTITIONED=Demo_PQ
QUEUE_NON_EXCLUSIVE=Demo_NQ
QUEUE_EXCLUSIVE=Demo_EQ
